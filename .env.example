# 이 파일은 템플릿입니다. 복사본을 `.env`로 만들어 값을 채우세요.
#   cp .env.example .env
# `.env`는 gitignore 되어 로컬에만 존재합니다. 운영 환경은 GitHub Actions secrets로 주입됩니다.

# Database (PostgreSQL)
# 로컬에서 docker compose 사용 시 예시:
#   DB_URL=jdbc:postgresql://localhost:5432/dallyrun
#   DB_USERNAME=dallyrun
#   DB_PASSWORD=dallyrun
#   DB_NAME=dallyrun
# DB_NAME / DB_USERNAME / DB_PASSWORD 는 docker-compose.yml 이 컨테이너 초기화에 그대로 사용합니다.
# DB_PORT 를 지정하면 호스트의 노출 포트를 바꿀 수 있습니다 (기본 5432).
DB_URL=
DB_USERNAME=
DB_PASSWORD=
DB_NAME=
DB_PORT=5432
DB_POOL_MAX=10
DB_POOL_MIN=5

# Redis
# 로컬에서 docker compose 사용 시: REDIS_HOST=localhost
# REDIS_PASSWORD 가 비어있으면 인증 없이 기동됩니다.
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (HMAC-SHA256 서명용, 최소 32바이트 권장)
JWT_SECRET=

# CORS (쉼표 구분으로 다중 origin 지정 가능)
CORS_ALLOWED_ORIGINS=

# Share
SHARE_TTL_DAYS=30

# File Storage (로컬 개발용 — 추후 S3 등으로 교체 예정)
# STORAGE_LOCAL_PATH: 서버 파일시스템 상 업로드 루트 경로 (상대/절대 경로 모두 가능)
# STORAGE_BASE_URL : 저장 파일을 외부에 노출할 때 조립할 베이스 URL
STORAGE_LOCAL_PATH=./uploads
STORAGE_BASE_URL=http://localhost:8080
